<mujoco model="foosball">

    <compiler angle="degree" meshdir="./assets/" autolimits="true" eulerseq="xyz" />

    <visual>
      <headlight ambient="0.7 0.7 0.7"/>
    </visual>

    <default>
        <default class="table">
            <geom contype="1" conaffinity="2" group="3" />
        </default>
        <default class="rod">
            <geom contype="1" conaffinity="2" group="3" type="cylinder" size="0.01 0.6" density="200" shellinertia="true" euler="0.0 90.0 0.0" pos="0.0 0.0 0.012233" />
        </default>

        <default class="ball">
            <geom contype="2" conaffinity="3" group="3"/>
        </default>

        <default class="visual">
          <geom type="mesh" contype="0" conaffinity="0" group="2"/>
        </default>
    </default>

    <asset>
        <mesh name="base_mesh" file="base.obj" />
        <mesh name="blue_1" file="blue1.obj" />
        <mesh name="blue_2" file="blue2.obj" />
        <mesh name="blue_3" file="blue3.obj" />

        <model name="player" file="player.xml" />

        <material
            name="soft_light_brown"
            rgba="0.68 0.52 0.36 1"
            specular="0.12"
            shininess="0.35"/>

        <material
            name="cherry_red"
            rgba="0.72 0.06 0.10 1"
            specular="0.18"
            shininess="0.30"/>

        <material
            name="navy_blue"
            rgba="0.03 0.10 0.28 1"
            specular="0.16"
            shininess="0.28"/>

        <texture
            name="checker_texture"
            type="2d"
            builtin="checker"
            rgb1="0.15 0.15 0.15"
            rgb2="0.85 0.85 0.85"
            width="512"
            height="512"
        />

        <material
            name="checker_material"
            texture="checker_texture"
            texrepeat="10 10"
            texuniform="true"
        />
    </asset>

    <actuator>
        <motor name="blue1_sj_0_a" joint="blue1_sj0" gear="1" ctrlrange="-50 50" />
        <motor name="blue1_sj_1_a" joint="blue1_sj1" gear="1" ctrlrange="-50 50" />
        <motor name="blue1_h_0_a" joint="blue1_h0" gear="1" ctrlrange="-40.0 40.0" />
        <motor name="blue1_h_1_a" joint="blue1_h1" gear="1" ctrlrange="-40.0 40.0" />

        <motor name="blue2_sj_a" joint="blue2_sj" gear="1" ctrlrange="-50 50" />
        <motor name="blue2_h_a" joint="blue2_h" gear="1" ctrlrange="-40.0 40.0" />

        <motor name="blue3_sj_a" joint="blue3_sj" gear="1" ctrlrange="-50 50" />
        <motor name="blue3_h_a" joint="blue3_h" gear="1" ctrlrange="-40.0 40.0" />

        <motor name="red1_sj_0_a" joint="red1_sj0" gear="1" ctrlrange="-50 50" />
        <motor name="red1_sj_1_a" joint="red1_sj1" gear="1" ctrlrange="-50 50" />
        <motor name="red1_h_0_a" joint="red1_h0" gear="1" ctrlrange="-40.0 40.0" />
        <motor name="red1_h_1_a" joint="red1_h1" gear="1" ctrlrange="-40.0 40.0" />

        <motor name="red2_sj_a" joint="red2_sj" gear="1" ctrlrange="-50 50" />
        <motor name="red2_h_a" joint="red2_h" gear="1" ctrlrange="-40.0 40.0" />

        <motor name="red3_sj_a" joint="red3_sj" gear="1" ctrlrange="-50 50" />
        <motor name="red3_h_a" joint="red3_h" gear="1" ctrlrange="-40.0 40.0" />
    </actuator>


    <sensor>
        <insidesite
            name="blue_goal_reached"
            site="blue_goal_zone"
            objtype="geom"
            objname="ball_coll"
        />
        <insidesite
            name="red_goal_reached"
            site="red_goal_zone"
            objtype="geom"
            objname="ball_coll"
        />
    </sensor>

    <worldbody>
        <body name="base" childclass="table" pos="0.0 0.0 0.0" euler="0.0 0.0 0.0">
            <site name="blue_goal_zone"
                type="box"
                pos="0.593284 0.0 0.289419"
                size="0.04 0.15 0.06"
                rgba="0.0 0.0 1.0 0.5"
            />

            <site name="red_goal_zone"
                type="box"
                pos="-0.580284 0.0 0.289419"
                size="0.04 0.15 0.06"
                rgba="1.0 0.0 0.0 0.5"
            />

            <geom name="base_vis" type="mesh" class="visual" mesh="base_mesh" euler="0.0 0.0 90.0" material="soft_light_brown" />
            <geom name="base_floor" type="box" pos="0.0 0.0 0.228605" size="0.619765	0.3133595	0.0256993" />

            <geom name="base_col_left_wall" type="box" pos="0.0 -0.325776 0.297165" size="0.55336 0.0138576 0.051112" />
            <geom name="base_col_right_right_wall" type="box" pos="0.288518 0.325776 0.297165" size="0.27668	0.0138576	0.051112" />
            <geom name="base_col_right_left_wall" type="box" pos="-0.305099 0.325776 0.297165" size="0.27668	0.0138576	0.051112" />
            <geom name="base_col_right_top_wall" type="box" pos="-0.00874 0.325776 0.337944" size="0.02002595	0.0138576	0.01125425" />
            <geom name="base_col_right_bot_wall" type="box" pos="-0.00874 0.325776 0.269701" size="0.0370646	0.0138576	0.01581445" />

            <geom name="base_goal1_left_wall" type="box" pos="-0.549865 -0.226787 0.297165" size="0.0205989	0.0949165	0.05" />
            <geom name="base_goal1_right_wall" type="box" pos="-0.549865 0.226787 0.297165" size="0.0205989	0.0949165	0.05" />

            <geom name="base_goal2_left_wall" type="box" pos="0.56324 -0.226787 0.297165" size="0.0205989	0.0949165	0.05" />
            <geom name="base_goal2_right_wall" type="box" pos="0.56324 0.226787 0.297165" size="0.0205989	0.0949165	0.05" />

            <!--  Could use replicate to rotate the reds to be a mirror image of the blues, but that will mean they'll have the same material in this model, easier to just copy and rotate-->
            <replicate count="2" offset="-0.656321 0.0 0.0">
                <body name="blue_1" euler="0.0 0.0 90.0" pos="0.448323 0.198511 0.302471">
                    <geom name="blue_1_vis" type="mesh" class="visual" mesh="blue_1" material="navy_blue" />
                    <geom class="rod" />

                    <body pos="0.076053 0.0 -0.021674">
                        <attach model="player" body="player" prefix="b1a" />
                    </body>
                    <body pos="-0.080805 0.0 -0.021674">
                        <attach model="player" body="player" prefix="b1b" />
                    </body>
                    <body pos="-0.228412 0.0 -0.021674">
                        <attach model="player" body="player" prefix="b1c" />
                    </body>

                    <joint name="blue1_sj" type="slide" axis="1.0 0.0 0.0" range="-0.247939 0.0" damping="0.01" frictionloss="0.003" />
                    <joint name="blue1_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />

                </body>
            </replicate>

            <body name="blue_2" euler="0.0 0.0 90.0" pos="0.319917 0.245792 0.302471">
                <geom name="blue_2_vis" type="mesh" class="visual" mesh="blue_2" material="navy_blue" />
                <geom class="rod" />

                <body pos="0.032212 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b2a" />
                </body>
                <body pos="-0.195161 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b2b" />
                </body>

                <joint name="blue2_sj" type="slide" axis="1.0 0.0 0.0" range="-0.32569 0.0" damping="0.01" frictionloss="0.003" />
                <joint name="blue2_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />
            </body>

            <body name="blue_3" euler="0.0 0.0 90.0" pos="0.067426 0.110197 0.302471">
                <geom name="blue_3_vis" type="mesh" class="visual" mesh="blue_3" material="navy_blue" />
                <geom class="rod" />

                <body pos="0.165844 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b3a" />
                </body>
                <body pos="0.043694 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b3b" />
                </body>
                <body pos="-0.080464 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b3c" />
                </body>
                <body pos="-0.201617 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b3d" />
                </body>
                <body pos="-0.310409 0.0 -0.021674">
                    <attach model="player" body="player" prefix="b3e" />
                </body>

                <joint name="blue3_sj" type="slide" axis="1.0 0.0 0.0" range="-0.074541 0.0" damping="0.01" frictionloss="0.003" />
                <joint name="blue3_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />
            </body>

            <!-- red people -->
            <body euler="0.0 0.0 180.0">
                <replicate count="2" offset="-0.656321 0.0 0.0">
                    <body name="red_1" euler="0.0 0.0 90.0" pos="0.448323 0.198511 0.302471">
                        <geom name="red_1_vis" type="mesh" class="visual" mesh="blue_1" material="cherry_red" />
                        <geom class="rod" />

                        <body pos="0.076053 0.0 -0.021674">
                            <attach model="player" body="player" prefix="r1a" />
                        </body>
                        <body pos="-0.080805 0.0 -0.021674">
                            <attach model="player" body="player" prefix="r1b" />
                        </body>
                        <body pos="-0.228412 0.0 -0.021674">
                            <attach model="player" body="player" prefix="r1c" />
                        </body>

                        <joint name="red1_sj" type="slide" axis="1.0 0.0 0.0" range="-0.247939 0.0" damping="0.01" frictionloss="0.003" />
                        <joint name="red1_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />
                    </body>
                </replicate>

                <body name="red_2" euler="0.0 0.0 90.0" pos="0.319917 0.245792 0.302471">
                    <geom name="red_2_vis" type="mesh" class="visual" mesh="blue_2" material="cherry_red" />
                    <geom class="rod" />

                    <body pos="0.032212 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r2a" />
                    </body>
                    <body pos="-0.195161 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r2b" />
                    </body>

                    <joint name="red2_sj" type="slide" axis="1.0 0.0 0.0" range="-0.32569 0.0" damping="0.01" frictionloss="0.003" />
                    <joint name="red2_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />
                </body>

                <body name="red_3" euler="0.0 0.0 90.0" pos="0.067426 0.110197 0.302471">
                    <geom name="red_3_vis" type="mesh" class="visual" mesh="blue_3" material="cherry_red" />
                    <geom class="rod" />

                    <body pos="0.165844 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r3a" />
                    </body>
                    <body pos="0.043694 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r3b" />
                    </body>
                    <body pos="-0.080464 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r3c" />
                    </body>
                    <body pos="-0.201617 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r3d" />
                    </body>
                    <body pos="-0.310409 0.0 -0.021674">
                        <attach model="player" body="player" prefix="r3e" />
                    </body>

                    <joint name="red3_sj" type="slide" axis="1.0 0.0 0.0" range="-0.074541 0.0" damping="0.01" frictionloss="0.003" />
                    <joint name="red3_h" type="hinge" axis="1.0 0.0 0.0" pos="0.0 0.0 0.012233" damping="0.01" frictionloss="0.002" armature="0.01" range="-135 135" />
                </body>
            </body>
        </body>

        <!-- The ball for the table -->
        <body name="ball" pos="0.02 0.02 0.305539">
            <geom name="ball_vis" type="sphere" size="0.02" class="visual" material="checker_material" />
            <geom name="ball_coll" type="sphere" size="0.02" class="ball" mass="0.02" />
            <freejoint name="ballfj" />
        </body>

    </worldbody>
</mujoco>
